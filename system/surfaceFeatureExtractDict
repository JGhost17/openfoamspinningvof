FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      surfaceFeatureExtractDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

tank.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       150;
    writeObj            yes;
}

impeller.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       150;
    writeObj            yes;
}

ami.stl
{
    extractionMethod    extractFromSurface;
    includedAngle       150;
    writeObj            yes;
}

