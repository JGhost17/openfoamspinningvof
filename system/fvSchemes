FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         Euler;
}

gradSchemes
{
    default         Gauss linear;
    grad(p_rgh)     Gauss linear;
}

divSchemes
{
    div(rhoPhi,U)        Gauss linearUpwind grad(U);
    div(phi,alpha.oilHeavy)       Gauss vanLeer;
    div(phirb,alpha.oilHeavy)     Gauss linear;
    div((muEff*dev2(T(grad(U))))) Gauss linear;
    div(phi,k)           Gauss upwind;
    div(phi,omega)       Gauss upwind;
}

laplacianSchemes
{
    default         Gauss linear corrected;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         corrected;
}

wallDist
{
    method          meshWave;
}

