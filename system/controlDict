FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application         interFoam;

startFrom           startTime;

startTime           0;

stopAt              endTime;

endTime             0.2;   // short laptop demo (~0.8 impeller revolution)

deltaT              1e-5;   // gentle impulsive-start; adjustTimeStep ramps up to maxCo/maxDeltaT

writeControl        adjustableRunTime;

writeInterval       0.02;

purgeWrite          0;

writeFormat         ascii;

writePrecision      6;

writeCompression    off;

timeFormat          general;

timePrecision       6;

runTimeModifiable   yes;

adjustableRunTime   yes;

adjustTimeStep      yes;
maxCo               10;
maxAlphaCo          2;
maxDeltaT           0.05;

// ************************************************************************* //
