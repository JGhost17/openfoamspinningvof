FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      transportProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

phases          (oilHeavy oilLight);

sigma           0.02;

oilHeavy
{
    transportModel  Newtonian;
    nu              3.5e-04;     // kinematic = mu/rho = 0.329 / 940
    rho             940;
}

oilLight
{
    transportModel  Newtonian;
    nu              5.0e-06;     // kinematic = mu/rho = 0.0041 / 820
    rho             820;
}

